# Default test/dev baseline keeps all providers on deterministic local stubs.
MIMIR_PROVIDER_MODE=stub

# Switch these to real only in local/provider integration environments.
# MIMIR_PROVIDER_MODE=real
# MIMIR_LLM_PROVIDER_MODE=real
# MIMIR_WEB_SEARCH_PROVIDER_MODE=real
# MIMIR_WEB_FETCH_PROVIDER_MODE=real

# Zhipu official SDK / API
ZHIPU_API_KEY=
MIMIR_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
MIMIR_ZHIPU_TIMEOUT_SECONDS=30

# Per-role model configuration
MIMIR_ZHIPU_MODEL_CLARIFICATION_NATURAL=glm-4.7
MIMIR_ZHIPU_MODEL_CLARIFICATION_OPTIONS=glm-4.7
MIMIR_ZHIPU_MODEL_REQUIREMENT_ANALYZER=glm-4.7
MIMIR_ZHIPU_MODEL_FEEDBACK_ANALYZER=glm-4.7
MIMIR_ZHIPU_MODEL_PLANNER=glm-4.7
MIMIR_ZHIPU_MODEL_COLLECTOR=glm-4.7
MIMIR_ZHIPU_MODEL_SUMMARIZER=glm-4.7
MIMIR_ZHIPU_MODEL_OUTLINER=glm-4.7
MIMIR_ZHIPU_MODEL_WRITER=glm-4.7

# Zhipu web_search over native HTTP
MIMIR_WEB_SEARCH_ENDPOINT_PATH=web_search
MIMIR_WEB_SEARCH_ENGINE=search_std
MIMIR_WEB_SEARCH_TIMEOUT_SECONDS=30

# Direct web fetch over native HTTP
MIMIR_WEB_FETCH_TIMEOUT_SECONDS=30
MIMIR_WEB_FETCH_USER_AGENT=mimir-api/0.1 (+https://github.com/Straytime/Mimir)
