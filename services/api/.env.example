# Database — defaults to local PostgreSQL with trust auth.
# MIMIR_DATABASE_URL=postgresql+psycopg://postgres@127.0.0.1:5432/postgres
# Railway Postgres users may also rely on platform-injected DATABASE_URL.
#
# Production (Railway) required:
# MIMIR_DATABASE_URL=postgresql+psycopg://...
# MIMIR_CORS_ALLOW_ORIGINS=https://mimir-web.vercel.app
# MIMIR_TASK_TOKEN_SECRET=
# MIMIR_ACCESS_TOKEN_SECRET=

# Default test/dev baseline keeps all providers on deterministic local stubs.
MIMIR_PROVIDER_MODE=stub

# Switch these to real only in local/provider integration environments.
# MIMIR_PROVIDER_MODE=real
# MIMIR_LLM_PROVIDER_MODE=real
# MIMIR_WEB_SEARCH_PROVIDER_MODE=real
# MIMIR_WEB_FETCH_PROVIDER_MODE=real
# MIMIR_E2B_PROVIDER_MODE=real

# Artifact storage
# Leave unset in local dev to use a temp directory.
# In Railway production, attach a Volume and either rely on
# RAILWAY_VOLUME_MOUNT_PATH auto-defaulting to "<mount>/mimir-artifacts",
# or override explicitly:
# MIMIR_ARTIFACT_ROOT_DIR=/data/mimir-artifacts

# Zhipu official SDK / API
ZHIPU_API_KEY=
MIMIR_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
MIMIR_ZHIPU_TIMEOUT_SECONDS=30

# Per-role model configuration
MIMIR_ZHIPU_MODEL_CLARIFICATION_NATURAL=glm-5
MIMIR_ZHIPU_MODEL_CLARIFICATION_OPTIONS=glm-5
MIMIR_ZHIPU_MODEL_REQUIREMENT_ANALYZER=glm-5
MIMIR_ZHIPU_MODEL_FEEDBACK_ANALYZER=glm-5
MIMIR_ZHIPU_MODEL_PLANNER=glm-5
MIMIR_ZHIPU_MODEL_COLLECTOR=glm-5
MIMIR_ZHIPU_MODEL_SUMMARIZER=glm-5
MIMIR_ZHIPU_MODEL_OUTLINER=glm-5
MIMIR_ZHIPU_MODEL_WRITER=glm-5

# Zhipu web_search over native HTTP
MIMIR_WEB_SEARCH_ENDPOINT_PATH=web_search
MIMIR_WEB_SEARCH_ENGINE=search_prime
MIMIR_WEB_SEARCH_TIMEOUT_SECONDS=30

# Jina Reader web_fetch (r.jina.ai)
# Optional: 为空时以免费无认证模式调用 Jina Reader API（受较低 RPM 限制）
JINA_API_KEY=
MIMIR_JINA_BASE_URL=https://r.jina.ai/
MIMIR_WEB_FETCH_TIMEOUT_SECONDS=30

# E2B Sandbox for python_interpreter
E2B_API_KEY=
MIMIR_E2B_REQUEST_TIMEOUT_SECONDS=30
MIMIR_E2B_EXECUTION_TIMEOUT_SECONDS=120
MIMIR_E2B_SANDBOX_TIMEOUT_SECONDS=600
