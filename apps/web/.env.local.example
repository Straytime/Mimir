# Local development: point the frontend at the local API server.
# Copy this file to .env.local to activate.
#
# Production Vercel deploys must set NEXT_PUBLIC_API_BASE_URL explicitly to the
# Railway API base URL. The same-origin fallback only fits reverse-proxy setups,
# not the current Vercel -> Railway split deployment.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
